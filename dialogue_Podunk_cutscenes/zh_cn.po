msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"

#. ﻿DIALOGUE_PODUNK_CUTSCENES_CANARY_REUNITE_1
msgid "[@]This canary seems sad."
msgstr "[@]这只金丝雀看上去很伤心。"

#. DIALOGUE_PODUNK_CUTSCENES_CANARY_REUNITE_2
msgid "[@]Show her the Canary chick?"
msgstr "[@]给她看金丝雀雏鸟吗？"

#. DIALOGUE_PODUNK_CUTSCENES_CANARY_REUNITE_2-OPT_0
msgid "Yes"
msgstr "是"

#. DIALOGUE_PODUNK_CUTSCENES_CANARY_REUNITE_2-OPT_1
msgid "No"
msgstr "否"

#. DIALOGUE_PODUNK_CUTSCENES_CANARY_REUNITE_10
msgid "[@]Overjoyed with her reunion, Laura started to sing."
msgstr "[@]劳拉因重逢感到非常高兴，她开始唱歌。"

#. DIALOGUE_PODUNK_CUTSCENES_CANARY_REUNITE_12
msgid "[@][PartyLead] remembered the tune."
msgstr "[@][PartyLead] 记住了这首曲子。"

#. DIALOGUE_PODUNK_CUTSCENES_CAROL_CALL_0
msgid "[@]Are you okay, [Ninten]?"
msgstr "[@]你还好吗，[Ninten]？"

#. DIALOGUE_PODUNK_CUTSCENES_CAROL_CALL_1
msgid "[@]What on earth is happening to our home?[WAIT@]I'm so scared..."
msgstr "[@]我们家到底发生了什么事了？[WAIT@]我好怕..."

#. DIALOGUE_PODUNK_CUTSCENES_CAROL_CALL_3
msgid "[@]If only your father were here now..."
msgstr "[@]如果你爸爸在这就好了..."

#. DIALOGUE_PODUNK_CUTSCENES_CAROL_CALL_6
msgid "[@]Oh! That must be him."
msgstr "[@]哦！那肯定是你爸爸。"

#. DIALOGUE_PODUNK_CUTSCENES_CAROL_CALL_7
msgid "[@]Could you get it, [Ninten]?"
msgstr "[@]你要接电话吗，[Ninten]？"

#. DIALOGUE_PODUNK_CUTSCENES_CAROL_CALL_SPEAKER_Carol
msgid "Carol"
msgstr "Carol"

#. DIALOGUE_PODUNK_CUTSCENES_CAROL_PHONE_0
msgid "[@]Telephone! [Ninten], would you please get it?"
msgstr "[@]有人打电话！[Ninten]，你想接吗？"

#. DIALOGUE_PODUNK_CUTSCENES_CAROL_PHONE_SPEAKER_Carol
msgid "Carol"
msgstr "Carol"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_0
msgid "[@]?!"
msgstr "[@]?!"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_1
msgid "[@]AHHHH!"
msgstr "[@]啊啊啊啊啊！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_2
msgid "[@]Z-Z-ZOMBIE!!!"
msgstr "[@]丧-丧-丧尸！！！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_4
msgid "[@]Stop lying! I can clearly tell you're a zombie![WAIT@]No normal person would walk around with clothes like that!"
msgstr "[@]别撒谎了！我可以很明确地告诉你你是个丧尸！[WAIT@]没有正常人会像那样穿着衣服走来走去！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_7
msgid "[@]You might be scary, zombie,"
msgstr "[@]你可能很吓人，丧尸，"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_8
msgid "[@]but [Pippi] never goes down without a fight!"
msgstr "[@]但[Pippi]从不会不战而败！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_REMATCH_0
msgid "[@]?!"
msgstr "[@]?!"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_REMATCH_1
msgid "[@]Y-Y-YOU AGAIN?!!"
msgstr "[@]又-又-又是你?!!"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_REMATCH_4
msgid "[@]I don't care how many times you come back, zombie,"
msgstr "[@]我不关心你回来几次，丧尸，"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_ATTACK_REMATCH_5
msgid "[@]but [Pippi] always wins!"
msgstr "[@]但[Pippi]还是会赢的！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_0
msgid "[@]Okay, okay! I surrender!"
msgstr "[@]好的，好的！我投降！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_1
msgid "[@]Just, please don't eat my brain..."
msgstr "[@]就是，请别吃我的脑子..."

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_3
msgid "[@]Huh?"
msgstr "[@]哈？"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_5
msgid "[@]So... you're NOT a zombie?"
msgstr "[@]所以...你不是个丧尸？"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_7
msgid "[@]Why didn't you say so earlier?[WAIT@]This entire situation could have been avoided!"
msgstr "[@]你怎么不早点说？[WAIT@]这整个局面本来是可以避免的！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_10
msgid "[@]Wait a minute... I think I finally recognize you.[WAIT@]You're Mimmie and Minnie's older brother, [Ninten]!"
msgstr "[@]等下...我想我终于认出你了。[WAIT@]你是Mimmie和Minnie的哥哥，[Ninten]！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_12
msgid "[@]Wow, the rumors are true. You really do look like that galactic farm boy!"
msgstr "[@]哇，传言是真的。你看起来真的很像那个银河农场的男孩！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_14
msgid "[@]What's that?[WAIT@]My mom's looking for me?[WAIT@]And you came all this way just to find me?"
msgstr "[@]什么？[WAIT@]我妈妈在找我？[WAIT@]你大老远跑来就是为了找我吗？"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_18
msgid "[@]Well, aren't you a brave boy!"
msgstr "[@]哦，你真是个勇敢的男孩！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_18-OPT_0
msgid "Yes"
msgstr "是"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_18-OPT_1
msgid "No"
msgstr "否"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_19
msgid "[@]Don't get too swell headed, ha-ha-ha!"
msgstr "[@]别太得意忘形了，哈-哈-哈！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_20
msgid "[@]Really? Well, I think you ARE brave.[WAIT@]You know what? I think I like you, [Ninten]. Do you like me?"
msgstr "[@]真的吗？嗯，我觉得你很勇敢。[WAIT@]你知道吗？我觉得我喜欢你，[Ninten]。你喜欢我吗？"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_21-OPT_0
msgid "Yes"
msgstr "是"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_21-OPT_1
msgid "No"
msgstr "否"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_22
msgid "[@]Yeah... You probably have someone special already..."
msgstr "[@]是的...你可能已经拥有了一个特别的人..."

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_23
msgid "[@]Oh me, oh my... You have such a way with words...[WAIT@]Here, take this shiny badge.[WAIT@]My mom said that as long as I have it, it'll give me courage."
msgstr "[@]哦，天哪，哦，天哪……你说话真有一套……[WAIT@]给，拿着这个闪亮的徽章吧。[WAIT@]我妈妈说，只要我拿着它，它就会给我勇气。"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_26
msgid "[@]But I think you'll probably need it more than me, so keep it!"
msgstr "[@]我觉得你可能比我更需要它，所以拿上吧！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_27
msgid "[@][Ninten] got the Courage Badge!"
msgstr "[@][@Ninten得到了勇气徽章！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_28
msgid "[@]Wait, you can't carry it? What a shame!"
msgstr "[@]等等，你不能带走它？真可惜！"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_29
msgid "[@]Now, let's go back to town."
msgstr "[@]现在，我们回镇上吧。"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_31
msgid "[@]Actually, can you please go first, [Ninten]? This place gives me the creeps."
msgstr "[@]不过你能走在前面吗，[Ninten]？这个地方令我\\n毛骨悚然。"

#. DIALOGUE_PODUNK_CUTSCENES_CATACOMBS_PIPPI_DEFEAT_33
msgid "[@][Pippi] joined your party!"
msgstr "[@][Pippi]加入了队伍！"

#. DIALOGUE_PODUNK_CUTSCENES_DOLL_ATTACK_2
msgid "[@]Ahhhh!"
msgstr "[@]啊啊啊！"

#. DIALOGUE_PODUNK_CUTSCENES_DOLL_ATTACK_4
msgid "[@]Big brother! Help!"
msgstr "[@]哥哥！救命啊！"

#. DIALOGUE_PODUNK_CUTSCENES_DOLL_ATTACK_SPEAKER_Mimmie
msgid "Mimmie"
msgstr "Mimmie"

#. DIALOGUE_PODUNK_CUTSCENES_DOLL_DEFEATED_2
msgid "[@]Is it over?"
msgstr "[@]这就完了？"

#. DIALOGUE_PODUNK_CUTSCENES_DOLL_DEFEATED_7
msgid "[@]It doesn't seem to be moving...[WAIT@]But I can still hear something coming out of it.[WAIT@][Ninten], can you check it to make sure it's dead?"
msgstr "[@]看样子它不动了...[WAIT@]但我还能听见它里面发出的声音。[WAIT@][Ninten]，你能不能检查一下，确定它死了？"

#. DIALOGUE_PODUNK_CUTSCENES_DOLL_DEFEATED_SPEAKER_Mimmie
msgid "Mimmie"
msgstr "Mimmie"

#. DIALOGUE_PODUNK_CUTSCENES_GGF_DIARY_0
msgid "[@][PartyLead] opened the present."
msgstr "[@][PartyLead]打开了礼物。"

#. DIALOGUE_PODUNK_CUTSCENES_GGF_DIARY_1
msgid "[@][Ninten] got his [color]Great Grand-Father's Diary[/color]!"
msgstr "[@][Ninten] 得到了他的[color]曾祖父的日记[/color]!"

#. DIALOGUE_PODUNK_CUTSCENES_GGF_DIARY_4
msgid "[@][Ninten]... Please... come find me..."
msgstr "[@][Ninten]...请...来找我..."

#. DIALOGUE_PODUNK_CUTSCENES_GGF_DIARY_5
msgid "[@]Seek the [color]shell in the cave[/color]..."
msgstr "[@]找到[color]山洞里的壳[/color]..."

#. DIALOGUE_PODUNK_CUTSCENES_GGF_DIARY_6
msgid "[@]Do so, and the wisdom of the world shall be unveiled..."
msgstr "[@]这样做，世界的智慧就会显露出来……"

#. DIALOGUE_PODUNK_CUTSCENES_GGF_DIARY_8
msgid "[@]Something awoke inside [Ninten]!"
msgstr "[@]有些东西在里面苏醒了[Ninten]！"

#. DIALOGUE_PODUNK_CUTSCENES_GGF_DIARY_9
msgid "[@][Ninten] learned Lifeup!"
msgstr "[@][Ninten]学会了生命提升！"

#. DIALOGUE_PODUNK_CUTSCENES_GGF_DIARY_10
msgid "[@]Press [color][ui_select][/color] and open your [color]PSI[/color] menu to use [color]Lifeup.[/color]"
msgstr "[@]按下[color][ui_select][/color] 并打开你的 [color]PSI[/color] 菜单以使用 [color]生命提升。[/color]"

#. DIALOGUE_PODUNK_CUTSCENES_GGF_DIARY_SPEAKER_???
msgid "???"
msgstr "？？？"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_GETSHOVEL_0
msgid "[@]Wow! You're a natural!"
msgstr "[@]哇！你是天生的！"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_GETSHOVEL_1
msgid "[@]It took me years to master that skill."
msgstr "[@]我花了几年来掌握这个技能。"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_GETSHOVEL_3
msgid "[@]Oh thank heavens, it's okay."
msgstr "[@]哦，感谢玉皇大帝，没事了。"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_GETSHOVEL_5
msgid "[@]You have my gratitude, boy.[WAIT@]Now if you'll excuse me, I have some zombies to put down."
msgstr "[@]我很感激你，小子。[WAIT@]如果你不介意的话，我要去把丧尸揍扁了。"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_GETSHOVEL_8
msgid "[@]Oh, and you can keep the bat.[WAIT@]I don't need it anymore."
msgstr "[@]哦，你可以留着这根球棒。[WAIT@]我不需要它了。"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_GETSHOVEL_SPEAKER_Iggy
msgid "Iggy"
msgstr "Iggy"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_0
msgid "[@]Oh, it's no use."
msgstr "[@]哦，这没用。"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_1
msgid "[@]I'll never get it back..."
msgstr "[@]这可就没辙了啊…"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_3
msgid "[@]Who's there?![WAIT@]A child?[WAIT@]What are you doing here?[WAIT@]This place is dangerous! Haven't you noticed all the zombies walking around?"
msgstr "[@]是谁？![WAIT@]一个小孩子？[WAIT@]你怎么会在这里？[WAIT@]这里很危险！你没看到到处都是四处走动的丧尸吗？"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_7
msgid "[@]Eh, whatever. I'm too busy to worry about that."
msgstr "[@]唉，随便吧。我太忙了，没空管这管那。"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_8
msgid "[@]Hold on..."
msgstr "[@]等一下..."

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_9
msgid "[@]I recognize that hat.[WAIT@]You must be a baseball player![WAIT@]Just my luck!"
msgstr "[@]我认得出那顶帽子。[WAIT@]你一定是个打棒球的！[WAIT@]真是走运！"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_12
msgid "[@]You see, I left my shovel over there, but when I came back, a strange root was blocking the way.[WAIT@]I know a special batting technique that could get rid of it."
msgstr "[@]你看，我之前把铲子搁在那里了，但当我回来时，冒出一个怪树根挡住了路。[WAIT@]我知道一种特殊的击打技巧，可以把它弄走。"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_14
msgid "[@]However, I've become too old to use it.[WAIT@]If you promise to help get my shovel back, I'll teach you this skill."
msgstr "[@]不过，我年纪大了，用不了了。[WAIT@]如果你答应帮我找回我的铲子，我就教你这个技巧。"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_16
msgid "[@]Do we have a deal?"
msgstr "[@]这事成不成？"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_16-OPT_0
msgid "Yes"
msgstr "是"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_16-OPT_1
msgid "No"
msgstr "否"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_17
msgid "[@]Please, it's urgent!"
msgstr "[@]拜托了，这件事要紧得很！"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_18
msgid "[@]Wonderful![WAIT@]All you need is a baseball bat.[WAIT@]Any bat, really.[WAIT@]To prove it, I'll give you my [color]Old Bat[/color] to test it out!"
msgstr "[@]太棒了！[WAIT@]你需要的是一根棒球棒。[WAIT@]任何球棒，真的。[WAIT@]为了证明这个 我将会把我的[color]老旧球棒[/color]给你来测试这个！"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_22
msgid "[@][Ninten] got the Old Bat!"
msgstr "[@][Ninten]得到了老旧球棒！"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_23
msgid "[@]Now, strength alone isn't enough to break this strange root."
msgstr "[@]光靠蛮力还不足以折断这奇怪的根。"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_24
msgid "[@]It's all about the technique![WAIT@]Try to imagine a [color][ui_cancel][/color] [if input:gamepad]button[else]key[/if] in your mind.[WAIT@]Then... Simply press it![WAIT@]This allows you to unleash a swing powerful enough to break any tough object.[WAIT@]Come on, try it!"
msgstr "[@]这个的关键全在技巧！[WAIT@] 试着在脑海中想象一个[color][ui_cancel][/color][if input:gamepad]按钮[else]按键[/if]。[WAIT@] 接下来... 只需按下它就好！[WAIT@] 这能让你施展出一记强力重击，威力足以击碎任何坚硬之物。[WAIT@] 来吧，试试看！"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_SWING_SPEAKER_Iggy
msgid "Iggy"
msgstr "Iggy"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_TRYTOLEAVE_0
msgid "[@]Hey, where do you think you're going?!"
msgstr "[@]嘿，你想到哪去？"

#. DIALOGUE_PODUNK_CUTSCENES_GRAVEDIGGER_TRYTOLEAVE_SPEAKER_Iggy
msgid "Iggy"
msgstr "Iggy"

#. DIALOGUE_PODUNK_CUTSCENES_GUARD_NORTH_MOVE_0
msgid "[@]The curfew has been lifted.[WAIT@]I can't see why travel was ever restricted, though...[WAIT@]Sorry, let me move out of the way."
msgstr "[@]宵禁已经解除了。[WAIT@]不过我也想不通之前为什么要限制通行...[WAIT@]对不起，我让路。"

#. DIALOGUE_PODUNK_CUTSCENES_GUARD_NORTH_MOVE_4
msgid "[@]I heard that you can communicate with Telepathy.[WAIT@]Have you heard of all the people talking about you?"
msgstr "[@]我听说你会通过心灵感应交流。[WAIT@]那你有听到所有人都在传你的事情吧？"

#. DIALOGUE_PODUNK_CUTSCENES_GUARD_NORTH_MOVE_6
msgid "[@]Oh right, you probably don't even need to “listen” to them!"
msgstr "[@]哦，不过你也不需要“听”说就能知道吧！"

#. DIALOGUE_PODUNK_CUTSCENES_GUARD_NORTH_MOVE_SPEAKER_Guard
msgid "Guard"
msgstr "守卫"

#. DIALOGUE_PODUNK_CUTSCENES_LEAVE_CANARY_VILLAGE_1
msgid "[@]All the canaries in the village are singing again.[WAIT@]I assume you've reunited the lost canary chick to its mother, correct?"
msgstr "[@]村里的所有金丝雀又开始唱歌了。[WAIT@]我想你已经让丢失的小金丝雀和妈妈团聚了，对吧？"

#. DIALOGUE_PODUNK_CUTSCENES_LEAVE_CANARY_VILLAGE_3
msgid "[@]Yep! We found her on the other side of a crack in the wall."
msgstr "[@]是的!我们在墙缝的另一边发现了她。"

#. DIALOGUE_PODUNK_CUTSCENES_LEAVE_CANARY_VILLAGE_4
msgid "[@]Great! I knew you'd find her![WAIT@]Oh, and by the way, the [color]mayor[/color] is itching to see you, [Ninten]...[WAIT@][Pippi], go with [Ninten] and help straighten this out."
msgstr "[@]太好了！我就知道你会找到她的！[WAIT@]哦，顺便说一下，[color]市长[/color]很想见你，[Ninten]……[WAIT@][Pippi]，去和[Ninten]一起解决这个问题。"

#. DIALOGUE_PODUNK_CUTSCENES_LEAVE_CANARY_VILLAGE_7
msgid "[@]Sure thing, mom!"
msgstr "[@]当然，妈妈！"

#. DIALOGUE_PODUNK_CUTSCENES_LEAVE_CANARY_VILLAGE_8
msgid "[@]Come on, [Ninten]! Let's go see the [color]mayor[/color]!"
msgstr "[@]来吧，[Ninten]！我们去见[color]市长[/color]吧！"

#. DIALOGUE_PODUNK_CUTSCENES_LEAVE_CANARY_VILLAGE_SPEAKER_Mrs._Lindgren
msgid "Mrs. Lindgren"
msgstr "Lindgren夫人"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_0
msgid "[@]Look for yourself, all the animals have escaped.[WAIT@]Only this Canary Chick is left.[WAIT@]We found this poor bird alone without its mommy at Canary Village, so we rescued it.[WAIT@]Yeah, I know, we're sort of like heroes.[WAIT@]Anyway, do you want it?"
msgstr "[@]你自己看看吧，所有动物都逃跑了。[WAIT@]只剩下了这只金丝雀雏鸟。[@]我们在金丝雀村发现了这只没有妈妈的可怜的小鸟，\\n所以我们救了它。[WAIT@]是的，我知道，我们跟英雄一样。[WAIT@]无论如何，你想要它吗？"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_5
msgid "[@]Oh, we gotta help it.[WAIT@]It must be so sad without its mommy."
msgstr "[@]哦，我们想帮助它。[WAIT@]它没有妈妈一定很伤心。"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_7
msgid "[@]You heard the little girl. Well, how about $55?"
msgstr "[@]你听到了这个小女孩。好的，我卖它55美元怎么样？"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_7-OPT_0
msgid "Yes"
msgstr "是"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_7-OPT_1
msgid "No"
msgstr "否"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_9
msgid "[@]You don't have enough money?"
msgstr "[@]你没有足够的钱？"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_10
msgid "[@]Well, if it's free, do you want it? Then take it!"
msgstr "[@]好的，如果不要钱，你想要它吗？然后把它带走吧！"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_11
msgid "[@]Take care of it. Come see us again!"
msgstr "[@]好好照顾它。欢迎下次光临！"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_12
msgid "[@]You got the Canary Chick!"
msgstr "[@]你得到了金丝雀雏鸟！"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_13
msgid "[@]Come on, let's go to Canary Village to see if we can find its mom!"
msgstr "[@]走吧，我们去金丝雀村看看能不能找到她的妈妈！"

#. DIALOGUE_PODUNK_CUTSCENES_MARSHAL_CANARY_SPEAKER_Marshal
msgid "Marshal"
msgstr "元帅"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_1
msgid "[@]Is she the lost girl, [Pippi]?[WAIT@]Well, that's just great.[WAIT@]I knew that you could fulfill your civic duty.[WAIT@]Applause,[BR]applause...[WAIT@]Here's your reward for your good deed."
msgstr "[@]她就是那个走失的女孩，[Pippi]吗？[WAIT@]嗯，那太好了。[WAIT@]我就知道你能履行身为公民的义务。[WAIT@]鼓掌，[BR]鼓掌...这是你做好事的报酬。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_6
msgid "[@][PartyLead] got $100!"
msgstr "[@][PartyLead]得到了100美元！"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_7
msgid "[@]Now that you're here, pretty [Pippi], we can finally call off the search party."
msgstr "[@]现在你在这了，美丽的[Pippi]，我们终于可以让搜索队停止寻找了。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_8
msgid "[@]Ahem."
msgstr "[@]嗯哼。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_9
msgid "[@]ABBOTT!!"
msgstr "[@]ABBOTT!!"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_11
msgid "[@]Yes, sir?"
msgstr "[@]是的，先生？"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_12
msgid "[@]Tell the [Pippi] search party that your mayor has finally found her."
msgstr "[@]告诉[Pippi]搜索队，你们的镇长终于找到她了。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_13
msgid "[@]Right away, sir!"
msgstr "[@]马上就去，先生！"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_15
msgid "[@]By the way, hero, there's been some commotion up at the [color]zoo[/color].[WAIT@]All the animals have broken out of their cages,[WAITBR]and most importantly, all the tourists have stopped coming.[WAIT@]For the sake of the economy, do you mind seeing what's up at the [color]zoo[/color]?"
msgstr "[@]顺便说一下，英雄，[color]动物园[/color]里发生了一些骚乱。[WAIT@]所有的动物都从笼子里跑了出来，[WAITBR]最重要的是，所有的游客都不来了。[WAIT@]看在经济发展的份上，你不介意看看[color]动物园[/color]里 发生什么吧？"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_18-OPT_0
msgid "Yes"
msgstr "是"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_18-OPT_1
msgid "No"
