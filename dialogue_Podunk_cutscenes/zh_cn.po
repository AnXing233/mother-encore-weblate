#. DIALOGUE_PODUNK_CUTSCENES_MINNIE_DOOR_SPEAKER_Minnie
msgid "Minnie"
msgstr "Minnie"

#. DIALOGUE_PODUNK_CUTSCENES_MINNIE_LEAVE_1
msgid "[@]Way to go, [Ninten]![WAIT@]But our house is still falling apart!"
msgstr "[@]干得好，[Ninten]！[WAIT@]但我们的房子还是散架的状态！"

#. DIALOGUE_PODUNK_CUTSCENES_MINNIE_LEAVE_4
msgid "[@]I wonder how Mimmie's doing. Let's go check if she's okay!"
msgstr "[@]我想知道Mimmie怎么样了。我们去看看她怎么样了！"

#. DIALOGUE_PODUNK_CUTSCENES_MINNIE_LEAVE_SPEAKER_Minnie
