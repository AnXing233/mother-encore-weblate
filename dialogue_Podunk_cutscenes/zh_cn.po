#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_19
msgid "[@]What's that? You'll go? Great, great, great![WAIT@]You'll need a key to get in."
msgstr "[@]什么？你要去？太好了，太好了，太好了！[WAIT@]你需要一把钥匙才能进去。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_21
msgid "[@]Ahem."
msgstr "[@]嗯哼。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_22
msgid "[@]ABBOTT!!"
msgstr "[@]ABBOTT!!"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_24
msgid "[@]*Pant, pant*... Yes... sir?"
msgstr "[@]*喘气，喘气*…是...先生?"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_25
msgid "[@]Give this young lad the [color]key to the zoo[/color]."
msgstr "[@]给这个小伙子[color]动物园的钥匙[/color]。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_26
msgid "[@]Right... away... sir!"
msgstr "[@]我...马上...先生！"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_28
msgid "[@][PartyLead] got the Zoo Key."
msgstr "[@][PartyLead] 得到了动物园钥匙。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_30
msgid "[@]Oh, and little girl, I'll need you to stay here for a bit.[WAIT@]There are some matters we need to attend to."
msgstr "[@]哦，小姑娘，我需要你在这里待一会儿。[WAIT@]有一些事情我们需要处理。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_32
msgid "[@]Oh... I guess it's time to say goodbye.[WAIT@]I had a lot of fun."
msgstr "[@]哦...我猜是时候说再见了。[WAIT@]我玩得很开心。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_34
msgid "[@]Remember to come by [color]my house[/color], I'll be waiting there to see you again!"
msgstr "[@]记得来[color]我家[/color]，我会在那里等你！"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_35
msgid "[@]By the way...[WAIT@]Do you think my hair needs styling?"
msgstr "[@]顺便说一下...[WAIT@]你觉得我需要做一下发型吗？"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_36-OPT_0
msgid "Yes"
msgstr "是"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_36-OPT_1
msgid "No"
msgstr "否"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_37
msgid "[@]Heehee, you didn't have to answer, cutie."
msgstr "[@]嘿嘿，你不用回答，小可爱。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_38
msgid "[@]I'll give you [color]something special[/color] if you do."
msgstr "[@]你要是来了的话，我就给你一份[color]特别的东西[/color]。"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_SPEAKER_Abbott
msgid "Abbott"
msgstr "Abbott"

#. DIALOGUE_PODUNK_CUTSCENES_MAYOR_PIPPI_RESCUE_SPEAKER_Mayor_Goodman
