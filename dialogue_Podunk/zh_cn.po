#. DIALOGUE_PODUNK_CANARY_THOUGHTS_1_SPEAKER_Canary
msgid "Canary"
msgstr "金丝雀"

#. DIALOGUE_PODUNK_CANARY_THOUGHTS_2_0
msgid "[@](Everyone's singing again!)"
