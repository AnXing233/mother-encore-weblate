msgid "{t0}{target} is no longer nauseous!"
msgstr "{t0}{target}不反胃了！"

#. BATTLE_MSG_HEAL_STATUS_NUMB
msgid "{t0}{target} was able to move again!"
msgstr "{t0}{target}又能动了！"

