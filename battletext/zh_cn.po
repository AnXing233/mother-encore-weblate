msgid "Oh no!! {t0}{target} caught the asthma!"
msgstr "噢不！！{t0}{target}的哮喘发作了！"

#. BATTLE_MSG_STATUS_BLINDED
msgid "{t0}{target} can't see!"
msgstr "{t0}{target}的眼睛看不见了！"

#. BATTLE_MSG_STATUS_BURNED
msgid "{t0}{target} caught on fire!"
msgstr "{t0}{target}身上着火了！"

#. BATTLE_MSG_STATUS_COLD
msgid "Oh no!! {t0}{target} caught the cold!"
msgstr "噢不！！{t0}{target}得了感冒！"

