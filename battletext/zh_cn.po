msgstr "{n0}{name}无法从敌人那里获得任何信息！"

#. BATTLE_MSG_NPC_PROTECTION
msgid "But {n1}{name} took the hit for {t1}{target}!"
msgstr "但是{n1}{name}站出来为{t1}{target}挡住了这一击！"

#. BATTLE_MSG_FLYING_MAN_COLLAPSED
msgid "The light faded from {n1}{name}'s eyes..."
msgstr "{n1}{name}的眼睛里失去了光彩···"

#. BATTLE_MSG_MORTAL_DAMAGE
msgid "{t0}{target} took mortal damage!"
msgstr "{t0}{target} 受到了致命一击！"

