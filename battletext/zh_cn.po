msgid "Inside the present, there {i6} {i3}{item}."
msgstr "礼物盒的里面有{i6}{i3}{item}。"

#. BATTLE_MSG_PRESENT_TAKING
msgid "{n0}{name} took {i5}."
msgstr "{n0}{name}把{i5}拿上了。"

