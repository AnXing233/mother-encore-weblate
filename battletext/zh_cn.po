#. BATTLE_MSG_LEVEL_UP_DEFENSE
msgid "Defense raised by {value}."
msgstr "防御增加了{value}。"

#. BATTLE_MSG_LEVEL_UP_SPEED
msgid "Speed raised by {value}."
msgstr "速度增加了{value}。"

#. BATTLE_MSG_LEVEL_UP_GUTS
msgid "Guts raised by {value}."
msgstr "勇气增加了{value}。"

#. BATTLE_MSG_LEARNING
msgid "{n0}{name} learned {skill}{skillLevel}!"
msgstr "{n0}{name}学会了{skill}{skillLevel}！"

