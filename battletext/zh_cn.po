msgid "{t0}{target} escaped from the Rope!"
msgstr "{t0}{target}挣脱了绳子！"

#. BATTLE_MSG_HEAL_STATUS_SLEEPING
msgid "{t0}{target} woke up!"
msgstr "{t0}{target}醒了！"

#. BATTLE_MSG_HEAL_STATUS_STONE
msgid "{t0}{target} softened up!"
msgstr "{t0}{target}软化了！"

#. BATTLE_MSG_HEAL_STATUS_SUNSTROKED
msgid "{t0}{target} no longer has sunstroke!"
msgstr "{t0}{target}不再软化了！"

#. BATTLE_MSG_HEAL_STATUS_UNCONSCIOUS
msgid "{t0}{target} was revived!"
msgstr "{t0}{target}复活了！"

#. BATTLE_MSG_HEAL_NONE
msgid "It had no effect on {t1}{target}!"
msgstr "它对{t1}{target}没有影响！"

#. BATTLE_MSG_HEAL_ALL
msgid "{t0}{target} was healed of all statuses!"
msgstr "{t0}{target}所有的异常状态消失了！"

