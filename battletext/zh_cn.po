msgstr "{t0}{target}的{stat}提高到最大值了。"

#. BATTLE_MSG_STATS_DOWN
msgid "{t0}{target}'s {stat} went down by {value}!"
msgstr "{t0}{target}的{stat}降低了{value}点！"

#. BATTLE_MSG_STATS_DOWN_MAX
msgid "{t0}{target}'s {stat} could not go any lower."
msgstr "{t0}{target}的{stat}降低到最小值了。"

